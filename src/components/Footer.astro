---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t(lang);
---

<footer class="section-pad border-t border-ink/10 py-16 bg-ink text-paper-lift">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-end justify-between gap-8">
    <div>
      <p class="font-display text-4xl sm:text-5xl font-bold tracking-tight">{copy.footer.thanks}</p>
      <p class="mt-3 text-paper-deep/80">{copy.footer.note}</p>
    </div>
    <p class="text-sm text-paper-deep/60">© {copy.hero.year} Nilay Dilekçi</p>
  </div>
</footer>
