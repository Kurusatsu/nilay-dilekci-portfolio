---
import type { Lang } from '../i18n/ui';
import { languages, otherLang, t, assetPath } from '../i18n/ui';
import { withBase } from '../lib/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t(lang);
const alt = otherLang(lang);
---

<header class="fixed inset-x-0 top-0 z-40">
  <div
    class="section-pad flex items-center justify-between py-4 backdrop-blur-md bg-paper/70 border-b border-ink/5"
  >
    <a href={withBase(`/${lang}/`)} class="font-display text-lg font-black tracking-tight">
      Nilay<span class="text-signal">.</span>
    </a>
    <nav class="hidden md:flex items-center gap-8 text-sm text-ink-soft">
      <a class="hover:text-signal transition-colors" href={withBase(`/${lang}/#work`)}>{copy.nav.work}</a>
      <a class="hover:text-signal transition-colors" href={withBase(`/${lang}/#about`)}>{copy.nav.about}</a>
      <a class="hover:text-signal transition-colors" href={withBase(`/${lang}/#skills`)}>{copy.nav.skills}</a>
      <a class="hover:text-signal transition-colors" href={withBase(`/${lang}/#contact`)}>{copy.nav.contact}</a>
      <a class="hover:text-signal transition-colors" href={withBase(`/${lang}/#cv`)}>{copy.nav.cv}</a>
    </nav>
    <div class="flex items-center gap-3">
      <a
        href={withBase(`/${alt}/`)}
        class="inline-flex items-center gap-1 rounded-full border border-ink/15 px-3 py-1.5 text-xs font-medium tracking-wide hover:border-signal hover:text-signal transition-colors"
        aria-label="Switch language"
      >
        <span class={lang === 'tr' ? 'text-signal' : 'text-ink-mute'}>{languages.tr}</span>
        <span class="text-ink-mute">/</span>
        <span class={lang === 'en' ? 'text-signal' : 'text-ink-mute'}>{languages.en}</span>
      </a>
      <a
        href={assetPath(copy.contact.cvHref)}
        download
        class="hidden sm:inline-flex rounded-full bg-ink px-4 py-2 text-xs font-medium text-paper-lift hover:bg-signal transition-colors"
      >
        {copy.nav.cv}
      </a>
    </div>
  </div>
</header>
