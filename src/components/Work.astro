---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { projects } from '../data/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t(lang);

const categories = ['posters', 'posts', 'campaigns', 'writing'] as const;
---

<section id="work" class="section-pad py-24 lg:py-32">
  <div class="max-w-6xl mx-auto">
    <div class="reveal max-w-3xl">
      <p class="eyebrow">{copy.work.eyebrow}</p>
      <h2 class="display mt-4 text-4xl sm:text-5xl lg:text-6xl">{copy.work.title}</h2>
    </div>

    {
      categories.map((cat) => {
        const items = projects.filter((p) => p.category === cat);
        return (
          <div class="mt-20">
            <h3 class="reveal font-display text-sm uppercase tracking-[0.22em] text-ink-mute mb-8">
              {copy.work.categories[cat]}
            </h3>
            <div class="grid md:grid-cols-2 gap-8 lg:gap-10">
              {items.map((project, i) => (
                <article class="reveal group" style={`transition-delay:${i * 70}ms`}>
                  <a href={`/${lang}/work/${project.id}/`} class="block">
                    <div class="relative overflow-hidden bg-paper-deep aspect-[4/5] sm:aspect-[5/6]">
                      <img
                        src={project.image}
                        alt={project.title[lang]}
                        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                        loading="lazy"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-ink/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                    </div>
                    <div class="mt-4 flex items-start justify-between gap-4">
                      <div>
                        <h4 class="font-display text-xl font-bold tracking-tight group-hover:text-signal transition-colors">
                          {project.title[lang]}
                        </h4>
                        <p class="mt-1 text-sm text-ink-mute leading-relaxed max-w-md">
                          {project.description[lang]}
                        </p>
                      </div>
                      <span class="mt-1 text-signal shrink-0 transition-transform duration-300 group-hover:translate-x-1">→</span>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</section>
