---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { withBase } from '../lib/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t(lang);
---

<section class="relative min-h-[100svh] overflow-hidden">
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_75%_35%,rgba(217,31,74,0.16),transparent_42%),linear-gradient(115deg,#d5dae4_0%,#eceef2_38%,#f6f7f9_100%)] animate-drift"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 opacity-[0.28]"
    style="background-image:linear-gradient(rgba(18,20,26,0.05) 1px, transparent 1px),linear-gradient(90deg, rgba(18,20,26,0.05) 1px, transparent 1px);background-size:64px 64px;"
    aria-hidden="true"
  >
  </div>

  <div class="absolute inset-y-0 right-0 w-full md:w-[52%] lg:w-[48%] pointer-events-none select-none">
    <div class="absolute inset-0 bg-gradient-to-l from-transparent via-transparent to-paper/90 md:to-paper/40 z-10"></div>
    <img
      src={withBase('/nilay.png')}
      alt=""
      class="absolute bottom-0 right-1/2 md:right-0 translate-x-1/2 md:translate-x-0 h-[72vh] md:h-[92vh] w-auto max-w-none object-contain drop-shadow-[0_40px_80px_rgba(18,20,26,0.28)] animate-fade-in"
      width="599"
      height="800"
      aria-hidden="true"
    />
  </div>

  <div class="relative z-20 min-h-[100svh] section-pad flex flex-col justify-center pb-16 pt-28 lg:justify-end lg:pb-20">
    <div class="max-w-xl lg:max-w-2xl">
      <p class="eyebrow animate-fade-up" style="animation-delay:0.05s">{copy.hero.year} · {copy.hero.role}</p>
      <h1
        class="display mt-4 text-[clamp(3.2rem,11vw,7.8rem)] text-ink animate-fade-up"
        style="animation-delay:0.15s"
      >
        {copy.hero.brand}
      </h1>
      <p
        class="mt-5 max-w-lg text-xl sm:text-2xl font-display font-extrabold tracking-tight text-ink-soft animate-fade-up"
        style="animation-delay:0.28s"
      >
        {copy.hero.headline}
      </p>
      <p class="mt-3 max-w-md text-base text-ink-mute leading-relaxed animate-fade-up" style="animation-delay:0.38s">
        {copy.hero.sub}
      </p>
      <div class="mt-8 flex flex-wrap gap-3 animate-fade-up" style="animation-delay:0.48s">
        <a
          href={withBase(`/${lang}/#work`)}
          class="rounded-full bg-signal px-6 py-3 text-sm font-medium text-white hover:bg-signal-deep transition-colors"
        >
          {copy.hero.ctaWork}
        </a>
        <a
          href={withBase(`/${lang}/#contact`)}
          class="rounded-full border border-ink/20 bg-paper-lift/70 backdrop-blur-sm px-6 py-3 text-sm font-medium hover:border-ink hover:bg-ink hover:text-paper-lift transition-colors"
        >
          {copy.hero.ctaContact}
        </a>
      </div>
    </div>
  </div>
</section>
