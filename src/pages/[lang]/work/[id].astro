---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { projects } from '../../../data/projects';
import type { Lang } from '../../../i18n/ui';
import { t } from '../../../i18n/ui';

export function getStaticPaths() {
  const langs: Lang[] = ['tr', 'en'];
  return langs.flatMap((lang) =>
    projects.map((project) => ({
      params: { lang, id: project.id },
      props: { project },
    }))
  );
}

const { lang, id } = Astro.params;
const locale = (lang === 'en' ? 'en' : 'tr') as Lang;
const { project } = Astro.props;
const copy = t(locale);
const gallery = project.images ?? [project.image];
const backLabel = locale === 'tr' ? '← Tüm işler' : '← All work';
const categoryLabel = copy.work.categories[project.category];
---

<BaseLayout lang={locale}>
  <Header lang={locale} />
  <main class="pt-28 section-pad pb-20">
    <div class="max-w-5xl mx-auto">
      <a href={`/${locale}/#work`} class="text-sm text-ink-mute hover:text-signal transition-colors">
        {backLabel}
      </a>
      <p class="eyebrow mt-8">{categoryLabel}</p>
      <h1 class="display mt-3 text-4xl sm:text-6xl max-w-3xl">{project.title[locale]}</h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-mute leading-relaxed">
        {project.description[locale]}
      </p>

      <div class="mt-12 space-y-8">
        {
          gallery.map((src) => (
            <div class="overflow-hidden bg-paper-deep">
              <img
                src={src}
                alt={project.title[locale]}
                class="w-full h-auto object-contain"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>
  </main>
  <Footer lang={locale} />
</BaseLayout>
